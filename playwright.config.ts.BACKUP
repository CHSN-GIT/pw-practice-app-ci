import { defineConfig, devices } from '@playwright/test';
import type { TestOptions } from './test-options'; 

/**
 * Read environment variables from file.
 * https://github.com/motdotla/dotenv
 */
import dotenv from 'dotenv';
import path from 'path';

// Esta línea idica a dotenv dónde se encuentra el fichero .env, para ello utilizamos path y ese es
// el motivo de importarlo también. La variable __dirname (como __filename) son constantes de NODE
// en este caso indica el path donde está ubicado el fichero playwright.config.ts (el mismo de .env)
// dotenv.config({ path: path.resolve(__dirname, '.env') });


// Determina el entorno (por defecto dev)
const environment = process.env.NODE_ENV || 'dev';

// Carga el archivo correspondiente
dotenv.config({
  path: path.resolve(__dirname, `.env.${environment}`),
});

// En la clase solo nos han indicado poner esta línea para activar dotenv pero ha variado la configuración
// en nuevas versiones y requiere las lineas anteriores y no solo esta como se indica en el curso
// require('dotenv').config()


/**
 * See https://playwright.dev/docs/test-configuration.
 */
// export default defineConfig({
  export default defineConfig<TestOptions>({   // una vez definido nuestro fichero test.options e importado el tipo
                                               // lo asignamos aquí y ya podremos utilizar la variable definida
  // timeout: 10000,
  // globalTimeout: 60000,
  testDir: './tests',
  /* Run tests in files in parallel */
  fullyParallel: false,
  /* Fail the build on CI if you accidentally left test.only in the source code. */
  forbidOnly: !!process.env.CI,
  /* Retry on CI only */
  retries: process.env.CI ? 2 : 1,
  // retries:  1,   // alternativa para definir así ya que producto del problema con la configuración del proyecto no reconoce "process"
  // He corregido este problema sumando la línea     "types": ["node"],   en "compilerOptions" del fichero tsconfig.json

  /* Opt out of parallel tests on CI. */
  workers: process.env.CI ? 1 : undefined, // Esta defición indica que la ejecuciones en CI es 1 worker y en local "undefined" (q implica 5)
  /* Reporter to use. See https://playwright.dev/docs/test-reporters */
  reporter: 'html',
  /* Shared settings for all the projects below. See https://playwright.dev/docs/api/class-testoptions. */
  use: {
    /* Base URL to use in actions like `await page.goto('')`.   baseURL es una Variable de Entorno*/
    /* Lo he reemplazado en todo el proyecto llamándolo por medio del caracter '/' -> await page.goto('/')*/
    // baseURL: 'http://localhost:4200/',
    // globalsQaURL: 'https://globalsqa.com/demo-site/draganddrop/',  // aquí utilizamos nuestra variable definida en test-options.ts
                                                                  // para utilizarla luego en nuestro test habremos de importarla

    /* Collect trace when retrying the failed test. See https://playwright.dev/docs/trace-viewer */



    trace: 'on-first-retry',
    // actionTimeout: 5000,
    // navigationTimeout: 5000
    video: {
      mode:'off',
      size: {width:1920, height: 1080}  // Full HD
    }
  },

  /* Configure projects for major browsers */
  projects: [
    {
      name: 'dev',
      use: { ...devices['Desktop Chrome'],
        baseURL: 'http://localhost:4200/'
       },
    },

    {
      name: 'stg',
      use: { ...devices['Desktop Chrome'],
        baseURL: 'http://localhost:4202/'
       },
    },

    {
      name: 'DragAndDrop',
      use: { ...devices['Desktop Chrome'],
        baseURL: 'https://globalsqa.com/demo-site/draganddrop/'
       },
